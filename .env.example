# ── shared ────────────────────────────────────────────────────────────────
# Comma-separated Monad mainnet RPC endpoints (first is primary)
RPC_URLS=https://rpc.monad.xyz,https://rpc1.monad.xyz,https://rpc2.monad.xyz,https://rpc3.monad.xyz

# ── deployer / keeper wallet (NEVER commit the real .env) ─────────────────
PRIVATE_KEY=0x...

# ── keeper (books + deploy blocks come from packages/shared MARKETS) ──────
POLL_MS=1000
DRY_RUN=true

# ── contracts (forge) ─────────────────────────────────────────────────────
MONAD_RPC_URL=https://rpc.monad.xyz
ETHERSCAN_API_KEY=

# ── natural-language smart orders (server-side only; never prefix with VITE_) ──
FREEMODEL_API_KEY=
FREEMODEL_BASE_URL=https://api.freemodel.dev
FREEMODEL_MODEL=gpt-5.4-mini
